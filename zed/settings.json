// Zed settings
{
  "current_line_highlight": "gutter",
  "cursor_shape": "underline",
  "relative_line_numbers": true,
  "buffer_line_height": "comfortable",
  "selection_highlight": false,
  "format_on_save": "on",
  "autosave": "on_focus_change",
  "ui_font_size": 16,
  "ui_font_family": "Monaspace Argon",
  "buffer_font_family": "Monaspace Neon",
  "buffer_font_size": 15,
  "icon_theme": "Bearded Icon Theme",
  "theme": {
    "mode": "system",
    "light": "Github Dark",
    "dark": "Github Dark"
  },
  "scrollbar": {
    "show": "never"
  },
  "tab_bar": {
    "show": false
  },
  "edit_predictions": {
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
      "enterprise_uri": null
    },
    "enabled_in_text_threads": false
  },
  "terminal": {
    "dock": "left",
    "font_family": "Monaspace Krypton",
    "font_size": 14,
    "line_height": "standard"
  },
  "git": {
    "git_gutter": "tracked_files",
    "gutter_debounce": null,
    "inline_blame": {
      "enabled": false
    },
    "hunk_style": null
  },
  "debugger": {
    "dock": "left"
  },
  "notification_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "left"
  },
  "project_panel": {
    "dock": "right",
    "indent_size": 20
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  }
}
